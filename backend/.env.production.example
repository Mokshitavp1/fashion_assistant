# Production environment
ENV=production

# Use managed MySQL or PostgreSQL in production (SQLite is blocked)
DATABASE_URL=mysql+pymysql://prod_user:secure_password@prod-db-host:3306/clothing_database
# DATABASE_URL=postgresql+psycopg://prod_user:secure_password@prod-db-host:5432/clothing_database

# DB pooling (recommended production baseline)
DB_POOL_SIZE=12
DB_MAX_OVERFLOW=24
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Concurrency for CPU-heavy image jobs per API instance
MAX_CONCURRENT_IMAGE_JOBS=2

# External inference queue
INFERENCE_QUEUE_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
INFERENCE_QUEUE_NAME=inference
INFERENCE_JOB_TIMEOUT=300
INFERENCE_RESULT_TTL=3600

# Application settings
DEBUG=False
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters

# CORS (comma-separated production origins)
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Token settings
ACCESS_TOKEN_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
