# Environment (dev, production, staging)
ENV=dev

# Database Configuration (local default: SQLite)
DATABASE_URL=sqlite:///./backend/clothing_database.db

# DB pooling (used for MySQL/PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Image inference worker concurrency per API instance
MAX_CONCURRENT_IMAGE_JOBS=4

# External inference queue
INFERENCE_QUEUE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
INFERENCE_QUEUE_NAME=inference
INFERENCE_JOB_TIMEOUT=300
INFERENCE_RESULT_TTL=3600

# Optional local MySQL example
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/clothing_database

# Email confirmation
# In development, the API returns a verification token in the response so testers
# can complete the flow without an actual inbox.
EMAIL_VERIFICATION_EXPIRATION_HOURS=24

# Example for production
# ENV=production
# DATABASE_URL=mysql+pymysql://prod_user:secure_password@prod-server:3306/clothing_database
# DB_POOL_SIZE=12
# DB_MAX_OVERFLOW=24
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# MAX_CONCURRENT_IMAGE_JOBS=2
# INFERENCE_QUEUE_ENABLED=true
# REDIS_URL=redis://redis-host:6379/0
# INFERENCE_QUEUE_NAME=inference
# INFERENCE_JOB_TIMEOUT=300
# INFERENCE_RESULT_TTL=3600

# Application Settings
DEBUG=True
LOG_LEVEL=INFO

# Security
SECRET_KEY=replace-with-a-long-random-secret

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
